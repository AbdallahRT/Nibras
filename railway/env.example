# Railway production secrets (optional local overrides). Copy railway/env.example to railway/env.local.
#
# The nibras-cli Railway project already includes Postgres. Prefer:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
#   DIRECT_DATABASE_URL=${{Postgres.DATABASE_PUBLIC_URL}}
#
# Optional: Neon + Upstash if you move off Railway Postgres (free, no credit card):
#   https://neon.tech  — DATABASE_URL (pooled), DIRECT_DATABASE_URL (direct)
#   https://upstash.com — REDIS_URL (redis://...)

RAILWAY_API_URL=https://web-production-f3a04.up.railway.app
RAILWAY_API_SERVICE=web
RAILWAY_WORKER_SERVICE=worker

# Set on Railway dashboard or via: ./scripts/railway-secrets.sh
DATABASE_URL=
DIRECT_DATABASE_URL=
REDIS_URL=
NIBRAS_ENCRYPTION_KEY=
AUTH_SECRET=
