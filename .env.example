# =============================================================================
# Nibras Backend — environment template
# Copy to `.env` and fill in real values. `.env` is git-ignored.
# All variables are validated at boot via Joi (src/config/validation.ts).
# =============================================================================

# ---- App ----
NODE_ENV=development
PORT=3000
# Path (no leading slash) where Swagger UI will be mounted.
SWAGGER_PATH=api/docs

# ---- MongoDB ----
# Full connection string. For docker-compose use `mongodb://mongodb:27017/nibras`.
MONGO_URI=mongodb://localhost:27017/nibras
MONGO_MAX_POOL_SIZE=10
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
# Retry policy used by @nestjs/mongoose when the initial connection fails.
MONGO_RETRY_ATTEMPTS=5
MONGO_RETRY_DELAY_MS=3000

# ---- Redis (cache + future real-time features) ----
# For docker-compose use `redis` as the host.
REDIS_HOST=localhost
REDIS_PORT=6379
# Leave blank if Redis has no auth (local dev default).
REDIS_PASSWORD=
REDIS_TTL_SECONDS=60

# ---- Auth (Phase 2) ----
# Required in production (min 32 chars). For local dev use any string >= 8 chars (do not leave blank).
AUTH_SECRET=nibras-dev-auth-secret-local
WEB_BASE_URL=http://localhost:3000
# Public API origin used for OAuth callback URLs.
API_BASE_URL=http://localhost:3000
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
RESEND_API_KEY=
NIBRAS_EMAIL_FROM=Nibras <noreply@nibras.dev>
SESSION_TTL_DAYS=30
MAGIC_LINK_TTL_SECONDS=300

# ---- Competitions (Phase 5) ----
# Set to false while running manual/smoke tests to avoid background cron noise.
COMPETITIONS_SYNC_ENABLED=false
CONTEST_SYNC_CRON=*/15 * * * *
PROBLEM_SYNC_CRON=0 */6 * * *
ACCOUNT_STATS_SYNC_CRON=0 */6 * * *
RANKING_CALC_CRON=*/30 * * * *
CONTEST_REMINDER_CRON=* * * * *
POST_CONTEST_CRON=*/10 * * * *

# ---- Assessments (Phase 6) ----
# Set EXECUTOR_ENABLED=true when Docker is available for sandboxed code runs.
EXECUTOR_ENABLED=false
EXECUTOR_MAX_CONCURRENT=4
EXECUTOR_DEFAULT_MEMORY_MB=256
EXECUTOR_DEFAULT_TIME_MS=5000
EXECUTOR_DEFAULT_DISK_MB=50
# MOSS plagiarism API user id (optional; uses local similarity when unset).
MOSS_USER_ID=
