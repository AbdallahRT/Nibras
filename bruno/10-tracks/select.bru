meta {
  name: Select Track
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/tracks/select
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "trackId": "{{trackId}}"
  }
}

script:post-response {
  if (res.status === 201 || res.status === 200) {
    bru.setVar("selectedTrackId", res.body.id);
  }
}
