meta {
  name: Upsert Progress
  type: http
  seq: 10
}

post {
  url: {{baseUrl}}/courses/{{courseId}}/videos/{{videoId}}/progress
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "watchedProgress": 0.5,
    "lastPositionSeconds": 60
  }
}

script:post-response {
  if (res.status === 201 && res.body.eventType) {
    console.log("Event:", res.body.eventType);
  }
}
